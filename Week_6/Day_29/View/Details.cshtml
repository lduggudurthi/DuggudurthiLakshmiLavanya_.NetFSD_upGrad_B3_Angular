@model WebApplication1.Models.Product

    <div class="card shadow p-4">

        <h3 class="mb-4">Product Details</h3>
        <hr />

        @if (Model == null)
        {
            <div class="text-danger">
                Product not found
            </div>
        }
        else
        {
        <p><b>Product Id:</b> @Model.ProductId</p>
        <p><b>Name:</b> @Model.ProductName</p>
        <p><b>Category:</b> @Model.Category</p>
        <p><b>Price:</b> ₹ @Model.Price</p>

            <div class="mt-3">
            <a class="btn btn-secondary" asp-action="Index" asp-controller="Product">Back</a>
            </div>
        }

    </div>
